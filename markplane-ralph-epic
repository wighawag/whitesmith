#!/bin/bash
# markplane-ralph-epic - Autonomous Coding Agent with Epic-based Branching
# Usage: markplane-ralph-epic [options] <work_dir>
#
# Options:
#   --agent-cmd <cmd>    Command to run the agent (default: "claude --dangerously-skip-permissions -p")
#   --max-iterations <n> Maximum iterations (default: 50)
#   --branch-prefix <p>  Branch prefix (default: "ralph")
#   --log-file <path>    Log all agent output to a file
#   --no-push            Skip pushing branches and creating PRs
#   --no-sleep           Skip sleep between iterations (for testing)
#   --help               Show this help
#
# This script creates separate branches for each epic.
# If an epic depends on another, it branches from the dependency.
# Each epic gets its own PR when complete.

# Default values
WORK_DIR=""
MAX_ITERATIONS=50
AGENT_CMD='claude --dangerously-skip-permissions -p'
BRANCH_PREFIX="ralph"
LOG_FILE=""
NO_PUSH=false
NO_SLEEP=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --agent-cmd)
            AGENT_CMD="$2"
            shift 2
            ;;
        --max-iterations)
            MAX_ITERATIONS="$2"
            shift 2
            ;;
        --branch-prefix)
            BRANCH_PREFIX="$2"
            shift 2
            ;;
        --log-file)
            LOG_FILE="$2"
            shift 2
            ;;
        --no-push)
            NO_PUSH=true
            shift
            ;;
        --no-sleep)
            NO_SLEEP=true
            shift
            ;;
        --help)
            head -20 "$0" | tail -n +2 | sed 's/^# //'
            exit 0
            ;;
        -*)
            echo "ERROR: Unknown option $1"
            exit 1
            ;;
        *)
            WORK_DIR="$1"
            shift
            ;;
    esac
done

# Default work dir to current directory
WORK_DIR=${WORK_DIR:-.}

ITERATION=0
COMPLETE_SIGNAL="RALPH_COMPLETE"
EPIC_COMPLETE_SIGNAL="EPIC_COMPLETE"
STATE_FILE=".ralph-epic-state"

# Validate and change to work directory
if [ ! -d "$WORK_DIR" ]; then
    echo "ERROR: Directory '$WORK_DIR' does not exist"
    exit 1
fi
cd "$WORK_DIR" || exit 1

echo "=== Ralph Wiggum Coding Agent (Epic Mode) ==="
echo "Working directory: $(pwd)"
echo "Max iterations: $MAX_ITERATIONS"
echo "Branch prefix: $BRANCH_PREFIX"
echo "Agent command: $AGENT_CMD"
echo "Log file: ${LOG_FILE:-<none>}"
echo "No push mode: $NO_PUSH"
echo ""

# Initialize log file if specified
if [ -n "$LOG_FILE" ]; then
    echo "=== Ralph Agent Log - $(date) ===" >> "$LOG_FILE"
    echo "Working directory: $(pwd)" >> "$LOG_FILE"
    echo "" >> "$LOG_FILE"
fi

# Fetch latest from origin (skip if no remote or in test mode)
if git remote | grep -q origin; then
    git fetch origin main 2>/dev/null || echo "WARNING: Could not fetch from origin"
fi

# Function to run agent command with optional TTY streaming and file logging
# - Streams output live when TTY is available
# - Logs to LOG_FILE if specified
run_agent() {
    local prompt="$1"
    local output
    
    if [ -t 1 ] && [ -n "$LOG_FILE" ]; then
        # TTY available AND log file - stream to both
        output=$(eval "$AGENT_CMD" '"$prompt"' 2>&1 | tee -a "$LOG_FILE" /dev/tty)
    elif [ -t 1 ]; then
        # TTY available only - stream to terminal
        output=$(eval "$AGENT_CMD" '"$prompt"' 2>&1 | tee /dev/tty)
    elif [ -n "$LOG_FILE" ]; then
        # Log file only - write to file
        output=$(eval "$AGENT_CMD" '"$prompt"' 2>&1 | tee -a "$LOG_FILE")
    else
        # No TTY, no log file - just capture
        output=$(eval "$AGENT_CMD" '"$prompt"' 2>&1)
    fi
    
    echo "$output"
}

# Function to sanitize epic name for branch name
sanitize_branch_name() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//'
}

# Function to save state
save_state() {
    local epic_id="$1"
    local epic_name="$2"
    local depends_on="$3"
    local branch_name="$4"
    cat > "$STATE_FILE" << EOF
SAVED_EPIC_ID="$epic_id"
SAVED_EPIC_NAME="$epic_name"
SAVED_DEPENDS_ON="$depends_on"
SAVED_BRANCH_NAME="$branch_name"
EOF
    echo "State saved: epic=$epic_id branch=$branch_name"
}

# Function to load state
load_state() {
    if [ -f "$STATE_FILE" ]; then
        source "$STATE_FILE"
        echo "State loaded: epic=$SAVED_EPIC_ID branch=$SAVED_BRANCH_NAME"
        return 0
    fi
    return 1
}

# Function to clear state
clear_state() {
    rm -f "$STATE_FILE"
    SAVED_EPIC_ID=""
    SAVED_EPIC_NAME=""
    SAVED_DEPENDS_ON=""
    SAVED_BRANCH_NAME=""
    echo "State cleared"
}

# Function to get or create branch for an epic
# Returns branch name via stdout
setup_epic_branch() {
    local epic_id="$1"
    local epic_name="$2"
    local depends_on="$3"
    
    local branch_name="${BRANCH_PREFIX}/epic-${epic_id}-$(sanitize_branch_name "$epic_name")"
    
    echo "Setting up branch for epic: $epic_name" >&2
    echo "Branch name: $branch_name" >&2
    
    # Check if we're already on this branch
    local current_branch=$(git branch --show-current)
    if [ "$current_branch" = "$branch_name" ]; then
        echo "Already on correct branch: $branch_name" >&2
        echo "$branch_name"
        return 0
    fi
    
    # Check if branch exists
    if git show-ref --verify --quiet "refs/heads/$branch_name"; then
        echo "Switching to existing branch '$branch_name'" >&2
        git checkout "$branch_name" >&2 || {
            echo "ERROR: Failed to checkout branch '$branch_name'" >&2
            return 1
        }
    else
        # Determine base branch (prefer origin/main, fall back to main)
        local base_branch="main"
        if git show-ref --verify --quiet "refs/remotes/origin/main"; then
            base_branch="origin/main"
        fi
        
        if [ -n "$depends_on" ]; then
            # Find the branch for the dependency
            local dep_branch=$(git branch -a | grep "${BRANCH_PREFIX}/epic-${depends_on}-" | head -1 | tr -d ' *')
            if [ -n "$dep_branch" ]; then
                base_branch="$dep_branch"
                echo "Branching from dependency: $base_branch" >&2
            else
                echo "WARNING: Dependency branch not found, using $base_branch" >&2
            fi
        fi
        
        echo "Creating new branch '$branch_name' from $base_branch" >&2
        git checkout -b "$branch_name" "$base_branch" >&2 || {
            echo "ERROR: Failed to create branch '$branch_name'" >&2
            return 1
        }
    fi
    
    echo "$branch_name"
    return 0
}

# Function to create PR for an epic
create_epic_pr() {
    local branch_name="$1"
    local epic_name="$2"
    local depends_on="$3"
    local pr_description="$4"
    
    # Skip push and PR creation if --no-push was specified
    if [ "$NO_PUSH" = true ]; then
        echo "Skipping push and PR creation (--no-push mode)"
        echo "Branch '$branch_name' is ready for manual push"
        return 0
    fi
    
    echo "Pushing branch '$branch_name' to origin..."
    git push -u origin "$branch_name" || {
        echo "ERROR: Failed to push branch to origin"
        return 1
    }
    
    # Determine base branch for PR
    local base_branch="main"
    if [ -n "$depends_on" ]; then
        local dep_branch=$(git branch -r | grep "${BRANCH_PREFIX}/epic-${depends_on}-" | head -1 | tr -d ' *' | sed 's|origin/||')
        if [ -n "$dep_branch" ]; then
            base_branch="$dep_branch"
        fi
    fi
    
    # Use Claude's description if provided, otherwise use default
    local body
    if [ -n "$pr_description" ]; then
        body="$pr_description

---
*Automated PR created by Ralph autonomous coding agent.*"
    else
        body="## Epic: $epic_name

## Changes
This PR contains all tasks completed for this epic.

## Dependencies
$([ -n "$depends_on" ] && echo "This PR depends on the PR for epic $depends_on" || echo "No dependencies - can be merged directly to main")

## Review
Please review the changes and merge when ready.

---
*Automated PR created by Ralph autonomous coding agent.*"
    fi
    
    echo "Creating Pull Request (base: $base_branch)..."
    if command -v gh &> /dev/null; then
        gh pr create --base "$base_branch" --head "$branch_name" \
            --title "feat: $epic_name" \
            --body "$body" || {
            echo "WARNING: Failed to create PR. You may need to create it manually."
            return 1
        }
        echo "PR created successfully!"
    else
        echo "WARNING: GitHub CLI (gh) not found. Please create PR manually."
        echo "Branch '$branch_name' has been pushed to origin."
    fi
    
    return 0
}

# Function to discover next epic (calls Claude in discovery mode)
discover_next_epic() {
    echo "=== Discovering next epic ===" >&2
    
    local discovery_prompt="You are an autonomous coding agent. Your ONLY task right now is to identify the next epic to work on.

INSTRUCTIONS:
1. Use markplane to list all epics and their dependencies
2. Find the first epic that:
   - Is not complete (has incomplete tasks)
   - Has all its dependencies (other epics) completed
3. Output ONLY the following three lines (nothing else):
   EPIC_ID: <id>
   EPIC_NAME: <name>
   DEPENDS_ON: <dependency_epic_id or empty if none>

4. If ALL epics are complete, output only:
   $COMPLETE_SIGNAL

DO NOT:
- Make any code changes
- Commit anything
- Do any implementation work

This is ONLY a discovery phase to determine which epic to work on next."

    run_agent "$discovery_prompt"
}

# Main iteration loop
while [ $ITERATION -lt $MAX_ITERATIONS ]; do
    ITERATION=$((ITERATION + 1))
    echo ""
    echo "=========================================="
    echo "=== Iteration $ITERATION of $MAX_ITERATIONS ==="
    echo "=========================================="

    # STEP 1: Determine which epic to work on
    EPIC_ID=""
    EPIC_NAME=""
    DEPENDS_ON=""
    BRANCH_NAME=""
    
    if load_state && [ -n "$SAVED_EPIC_ID" ] && [ -n "$SAVED_BRANCH_NAME" ]; then
        # Resume existing epic
        EPIC_ID="$SAVED_EPIC_ID"
        EPIC_NAME="$SAVED_EPIC_NAME"
        DEPENDS_ON="$SAVED_DEPENDS_ON"
        BRANCH_NAME="$SAVED_BRANCH_NAME"
        echo "Resuming epic: $EPIC_ID ($EPIC_NAME)"
    else
        # Discover next epic
        echo "No saved state - discovering next epic..."
        DISCOVERY_OUTPUT=$(discover_next_epic)
        echo "$DISCOVERY_OUTPUT"
        
        # Check for all complete
        if echo "$DISCOVERY_OUTPUT" | grep -q "$COMPLETE_SIGNAL"; then
            echo ""
            echo "=== ALL EPICS COMPLETED! ==="
            echo "All tasks in all epics have been implemented."
            echo ""
            echo "Created PRs:"
            if command -v gh &> /dev/null; then
                gh pr list --search "head:${BRANCH_PREFIX}/epic-"
            else
                echo "Use 'gh pr list' to see all Ralph PRs"
            fi
            clear_state
            exit 0
        fi
        
        # Extract epic info
        EPIC_ID=$(echo "$DISCOVERY_OUTPUT" | grep -E "^[[:space:]]*EPIC_ID:" | head -1 | sed 's/.*EPIC_ID:[[:space:]]*//')
        EPIC_NAME=$(echo "$DISCOVERY_OUTPUT" | grep -E "^[[:space:]]*EPIC_NAME:" | head -1 | sed 's/.*EPIC_NAME:[[:space:]]*//')
        DEPENDS_ON=$(echo "$DISCOVERY_OUTPUT" | grep -E "^[[:space:]]*DEPENDS_ON:" | head -1 | sed 's/.*DEPENDS_ON:[[:space:]]*//')
        
        if [ -z "$EPIC_ID" ] || [ -z "$EPIC_NAME" ]; then
            echo "ERROR: Could not extract epic information from discovery"
            echo "Discovery output was:"
            echo "$DISCOVERY_OUTPUT"
            exit 1
        fi
        
        echo ""
        echo "Discovered epic: $EPIC_ID - $EPIC_NAME"
        [ -n "$DEPENDS_ON" ] && echo "Depends on: $DEPENDS_ON"
    fi
    
    # STEP 2: Ensure we're on the correct branch BEFORE running Claude
    if [ -z "$BRANCH_NAME" ]; then
        BRANCH_NAME=$(setup_epic_branch "$EPIC_ID" "$EPIC_NAME" "$DEPENDS_ON")
        if [ $? -ne 0 ]; then
            echo "ERROR: Failed to setup epic branch"
            exit 1
        fi
    else
        # Verify we're on the correct branch
        CURRENT_BRANCH=$(git branch --show-current)
        if [ "$CURRENT_BRANCH" != "$BRANCH_NAME" ]; then
            echo "Switching to branch: $BRANCH_NAME"
            git checkout "$BRANCH_NAME" || {
                echo "ERROR: Failed to checkout branch '$BRANCH_NAME'"
                exit 1
            }
        fi
    fi
    
    # Save state
    save_state "$EPIC_ID" "$EPIC_NAME" "$DEPENDS_ON" "$BRANCH_NAME"
    
    echo ""
    echo "Working on branch: $BRANCH_NAME"
    echo ""
    
    # STEP 3: Run Claude to work on tasks (branch is already set up)
    WORK_PROMPT="You are an autonomous coding agent working on epic: $EPIC_ID ($EPIC_NAME)

CURRENT BRANCH: $BRANCH_NAME
You are already on the correct branch. All commits will go to this branch.

MANDATORY: After completing ANY task, you MUST commit your changes.
Uncommitted work = incomplete work.

WORKFLOW:
1. First, mark the epic as 'in-progress' using markplane (if not already):
   markplane epic status $EPIC_ID in-progress
2. Find the first incomplete task in this epic using markplane
3. Mark the task as 'in-progress':
   markplane task status <TASK_ID> in-progress
4. Implement it following the specs
5. Check the acceptance criteria
6. If they pass, mark the task as 'done':
   markplane task status <TASK_ID> done
7. Run: markplane sync
8. COMMIT your changes: git add . ':!.ralph-epic-state' && git commit -m 'feat($EPIC_ID): <description>'
9. If all tasks IN THIS EPIC are now done:
   - Mark the epic as 'done': markplane epic status $EPIC_ID done
   - Run: markplane sync
   - Write: $EPIC_COMPLETE_SIGNAL
   - Provide a PR description:
     PR_DESCRIPTION_START
     <your detailed PR description>
     PR_DESCRIPTION_END

IMPORTANT:
- One task per iteration
- You MUST commit after completing the task
- Do NOT switch branches - stay on $BRANCH_NAME
- Always update status: epic and task to 'in-progress' when starting, 'done' when complete

FINAL CHECK: Did you commit? If not, do it now:
git add . ':!.ralph-epic-state' && git commit -m 'feat($EPIC_ID): <description>'"

    OUTPUT=$(run_agent "$WORK_PROMPT")
    EXIT_CODE=$?
    if [ $EXIT_CODE -ne 0 ]; then
        echo "ERROR: Claude command failed with exit code $EXIT_CODE"
        exit 1
    fi
    
    # STEP 4: Verify we're still on the correct branch
    CURRENT_BRANCH=$(git branch --show-current)
    if [ "$CURRENT_BRANCH" != "$BRANCH_NAME" ]; then
        echo "!!! WARNING: Branch changed unexpectedly to '$CURRENT_BRANCH' !!!"
        echo "Switching back to $BRANCH_NAME"
        git checkout "$BRANCH_NAME"
    fi
    
    # STEP 5: Commit any uncommitted changes (safety net)
    if ! git diff --quiet || ! git diff --cached --quiet; then
        echo "Found uncommitted changes - committing as safety net"
        git add . ':!.ralph-epic-state'
        git commit -m "feat($EPIC_ID): implement task (auto-commit)"
    fi
    
    # STEP 6: Check for epic completion
    if echo "$OUTPUT" | grep -q "$EPIC_COMPLETE_SIGNAL"; then
        echo ""
        echo "=== EPIC COMPLETED: $EPIC_NAME ==="
        
        # Extract PR description if provided
        PR_DESCRIPTION=$(echo "$OUTPUT" | sed -n '/PR_DESCRIPTION_START/,/PR_DESCRIPTION_END/p' | sed '1d;$d')
        
        # Create PR for this epic
        create_epic_pr "$BRANCH_NAME" "$EPIC_NAME" "$DEPENDS_ON" "$PR_DESCRIPTION"
        
        # Clear state so next iteration discovers the next epic
        clear_state
        
        echo ""
        echo "Epic complete! Will discover next epic on next iteration."
        echo ""
    fi
    
    # Check for full completion (all epics done)
    if echo "$OUTPUT" | grep -q "$COMPLETE_SIGNAL"; then
        echo ""
        echo "=== ALL EPICS COMPLETED! ==="
        echo "All tasks in all epics have been implemented."
        echo ""
        echo "Created PRs:"
        if command -v gh &> /dev/null; then
            gh pr list --search "head:${BRANCH_PREFIX}/epic-"
        else
            echo "Use 'gh pr list' to see all Ralph PRs"
        fi
        
        clear_state
        exit 0
    fi

    # Pause between iterations (avoid rate limiting)
    if [ "$NO_SLEEP" = false ]; then
        sleep 5
    fi
done

echo ""
echo "=== Iteration limit reached ==="
echo "Check markplane for current status."
echo ""
echo "Active Ralph branches:"
git branch | grep "${BRANCH_PREFIX}/"
