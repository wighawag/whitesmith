{
	"name": "ralph-epic",
	"version": "0.0.0",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"ralph-epic": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"dependencies": {
		"commander": "^14.0.3",
		"simple-git": "^3.33.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@types/node": "^25.2.0",
		"as-soon": "^0.1.5",
		"cross-env": "^10.1.0",
		"prettier": "^3.8.0",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"prepublishOnly": "pnpm format:check && pnpm build",
		"release": "pnpm prepublishOnly && git push --all && pnpm changeset publish && git push --tags",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"build": "tsc",
		"dev": "as-soon -w src pnpm build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "./test-ralph-epic.sh --typescript && ./test-branch-skip.sh --typescript"
	}
}
